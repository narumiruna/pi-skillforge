{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://github.com/narumiruna/pi-skillforge/schemas/memory.schema.json",
	"title": "pi-skillforge memory entry",
	"type": "object",
	"additionalProperties": false,
	"required": [
		"id",
		"type",
		"title",
		"scope",
		"confidence",
		"hits",
		"created_at",
		"updated_at",
		"trigger",
		"symptom",
		"root_cause",
		"fix",
		"verification"
	],
	"properties": {
		"id": {
			"type": "string",
			"pattern": "^[a-z0-9][a-z0-9-]*$"
		},
		"type": {
			"enum": ["gotcha", "decision", "pattern"]
		},
		"title": {
			"type": "string",
			"minLength": 1
		},
		"scope": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"languages": { "$ref": "#/$defs/stringList" },
				"tools": { "$ref": "#/$defs/stringList" },
				"files": { "$ref": "#/$defs/stringList" },
				"projects": { "$ref": "#/$defs/stringList" }
			},
			"anyOf": [
				{ "required": ["languages"] },
				{ "required": ["tools"] },
				{ "required": ["files"] },
				{ "required": ["projects"] }
			]
		},
		"skills": { "$ref": "#/$defs/stringList" },
		"compatible_skills": { "$ref": "#/$defs/stringList" },
		"excluded_skills": { "$ref": "#/$defs/stringList" },
		"confidence": {
			"enum": ["draft", "observed", "confirmed", "deprecated"]
		},
		"hits": {
			"type": "integer",
			"minimum": 1
		},
		"created_at": {
			"type": "string",
			"pattern": "^\\d{4}-\\d{2}-\\d{2}$"
		},
		"updated_at": {
			"type": "string",
			"pattern": "^\\d{4}-\\d{2}-\\d{2}$"
		},
		"trigger": { "$ref": "#/$defs/nonEmptyStringList" },
		"symptom": { "$ref": "#/$defs/nonEmptyStringList" },
		"root_cause": { "$ref": "#/$defs/nonEmptyStringList" },
		"fix": { "$ref": "#/$defs/nonEmptyStringList" },
		"verification": { "$ref": "#/$defs/nonEmptyStringList" }
	},
	"$defs": {
		"stringList": {
			"type": "array",
			"items": { "type": "string" }
		},
		"nonEmptyStringList": {
			"type": "array",
			"minItems": 1,
			"items": { "type": "string", "minLength": 1 }
		}
	}
}
